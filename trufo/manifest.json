{
  "manifest_version": 3,
  "name": "Trufo",
  "version": "1.0.2",
  "description": "Quickly create and share encrypted secrets via Trufo — directly from your browser.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://trufo.maimons.dev/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Trufo"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
